# Only exclude non-skill artifacts
/.git/
/.usage.json
/.archive/
/.curator_backups/

# OS files
.DS_Store
Thumbs.db

# Editor temp files
*.swp
*.swo
*~

# Large binary artifacts (keep scripts but exclude generated files)
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Pipeline outputs (videos/images generated by media-pipeline)
media-pipeline/scripts/output/

# Hub artifacts (audit logs, index caches)
.hub/

# Curator backups
.curator_backups/

# Local config backups
*.bak
*.orig
